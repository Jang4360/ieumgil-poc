{
  "distance_influence": 35,
  "priority": [
    { "if": "road_class == STEPS", "multiply_by": 0 },
    { "if": "crossing == TRAFFIC_SIGNALS", "multiply_by": 1.2 },
    { "if": "crossing == UNCONTROLLED", "multiply_by": 0.6 },
    { "if": "crossing == UNMARKED", "multiply_by": 0.4 },
    { "if": "has_curb_gap", "multiply_by": 1.15 },
    { "if": "has_elevator", "multiply_by": 1.2 },
    { "if": "width_meter > 0 && width_meter < 0.8", "multiply_by": 0 },
    { "if": "width_meter > 0 && width_meter < 1.0", "multiply_by": 0.35 },
    { "if": "width_meter > 0 && width_meter >= 1.2", "multiply_by": 1.05 },
    { "if": "surface == COBBLESTONE", "multiply_by": 0.55 },
    { "if": "surface == GRAVEL || surface == FINE_GRAVEL", "multiply_by": 0.35 },
    { "if": "surface == GROUND || surface == DIRT || surface == GRASS || surface == SAND || surface == OTHER", "multiply_by": 0.2 },
    { "if": "footway == SIDEWALK", "multiply_by": 1.15 },
    { "if": "footway == ACCESS_AISLE", "multiply_by": 1.1 }
  ],
  "speed": [
    { "if": "average_slope >= 7", "limit_to": 2.0 },
    { "else_if": "average_slope >= 4", "multiply_by": 0.75 },
    { "if": "surface == COBBLESTONE", "limit_to": 3.0 },
    { "if": "surface == GRAVEL || surface == FINE_GRAVEL", "limit_to": 2.5 },
    { "if": "surface == GROUND || surface == DIRT || surface == GRASS || surface == SAND || surface == OTHER", "limit_to": 2.0 }
  ]
}
